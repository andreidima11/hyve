{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@hyve/*": ["static/js/*"],
      "/static/hyveview/bridge.js": ["static/hyveview/bridge.d.ts"],
      "/static/hyveview/host.js": ["static/hyveview/host.d.ts"],
      "/static/hyveview/cards/loader.js": ["static/hyveview/cards/loader.d.ts"],
      "/static/hyveview/editor/modal.js": ["static/hyveview/editor/modal.d.ts"],
      "/static/hyveview/elements/camera_stream.js": ["static/hyveview/elements/camera_stream.d.ts"],
      "/static/hyveview/elements/camera_carousel.js": ["static/hyveview/elements/camera_carousel.d.ts"],
      "/static/hyveview/cards/fusion_solar/card.js": ["static/hyveview/cards/fusion_solar/card.d.ts"],
      "/static/hyveview/core/store.js": ["static/hyveview/core/store.d.ts"]
    }
  },
  "include": ["static/js/**/*.ts", "static/js/**/*.js", "static/js/types/**/*.d.ts"],
  "exclude": ["node_modules"]
}
