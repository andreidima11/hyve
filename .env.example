# Hyve example environment
# Copy to .env and fill in real values.

# Required in production for stable JWT sessions
HYVE_SECRET_KEY=replace_with_a_random_secret

# Optional: override Home Assistant token from config.json
HA_TOKEN=

# Optional: WAHA credentials
WAHA_USERNAME=
WAHA_PASSWORD=

# Optional: Firebase Cloud Messaging service account JSON path
HYVE_FCM_SERVICE_ACCOUNT_PATH=

# Optional feature toggles
# DISABLE_SHELL=1
# DISABLE_SEARXNG=1
# DISABLE_WAHA=1
