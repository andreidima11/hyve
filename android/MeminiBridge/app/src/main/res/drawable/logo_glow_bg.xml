<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer nebula glow, matches web memini hero galaxy before -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="140dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#0F38bdf8"
                android:centerColor="#0Aa855f7"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Inner logo glow, matches web memini logo hero after -->
    <item
        android:left="20dp"
        android:top="20dp"
        android:right="20dp"
        android:bottom="20dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#1438bdf8"
                android:centerColor="#0838bdf8"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
