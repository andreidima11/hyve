<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#030712"
    android:fillViewport="true">

    <!-- Full-screen centered layout — mirrors the web login page -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Ambient background glow -->
        <View
            android:id="@+id/settings_ambient_glow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Glass card — centered, padded -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_card_bg"
                android:padding="28dp"
                android:elevation="8dp"
                android:gravity="center_horizontal">

                <!-- Logo only, no glow -->
                <TextView
                    android:id="@+id/settings_logo_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="4dp"
                    android:text="Hyve"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.04" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:text="@string/settings_subtitle"
                    android:textSize="13sp"
                    android:textColor="#64748b" />

                <!-- ═══ External URL ═══ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_external_url"
                    android:textColor="#94a3b8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/settings_url_external"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://your-server.duckdns.org:8443"
                    android:inputType="textUri"
                    android:background="@drawable/input_background_glass"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="#e2e8f0"
                    android:textColorHint="#475569"
                    android:textSize="14sp"
                    android:layout_marginBottom="20dp" />

                <!-- ═══ Local URL ═══ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_local_url"
                    android:textColor="#94a3b8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/settings_url_local"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="http://192.168.1.100:3000"
                    android:inputType="textUri"
                    android:background="@drawable/input_background_glass"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textColor="#e2e8f0"
                    android:textColorHint="#475569"
                    android:textSize="14sp"
                    android:layout_marginBottom="20dp" />

                <!-- ═══ Home WiFi SSID ═══ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_wifi_label"
                    android:textColor="#94a3b8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.03"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <EditText
                        android:id="@+id/settings_wifi_ssid"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/settings_wifi_hint"
                        android:inputType="text"
                        android:background="@drawable/input_background_glass"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:textColor="#e2e8f0"
                        android:textColorHint="#475569"
                        android:textSize="14sp"
                        android:layout_marginEnd="10dp" />

                    <Button
                        android:id="@+id/settings_detect_wifi"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/settings_detect"
                        android:textColor="#38bdf8"
                        android:background="@drawable/btn_detect_glass"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <TextView
                    android:id="@+id/settings_current_ssid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#475569"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_wifi_explanation"
                    android:textColor="#3b4261"
                    android:textSize="10sp"
                    android:lineSpacingMultiplier="1.3"
                    android:layout_marginBottom="28dp" />

                <!-- ═══ Save — gradient button ═══ -->
                <Button
                    android:id="@+id/settings_save"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="@string/settings_save"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:letterSpacing="0.02"
                    android:background="@drawable/btn_gradient_accent"
                    android:elevation="4dp"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ═══ Permissions Card ═══ -->
            <!-- ═══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/glass_card_bg"
                android:padding="24dp"
                android:elevation="8dp"
                android:layout_marginTop="16dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:text="\uD83D\uDD10"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:background="@drawable/glass_card_bg"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Permissions"
                            android:textColor="#f8fafc"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manage app permissions for device features."
                            android:textColor="#64748b"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Microphone ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Microphone"
                            android:textColor="#e2e8f0"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Required for voice input (Whisper)"
                            android:textColor="#64748b"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/perm_mic_status"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="Not set"
                        android:textColor="#94a3b8"
                        android:textSize="12sp"
                        android:background="@drawable/input_background_glass"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/perm_mic_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Allow"
                        android:textColor="#38bdf8"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_detect_glass"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- ── Camera ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Camera"
                            android:textColor="#e2e8f0"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Required for photo capture"
                            android:textColor="#64748b"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/perm_camera_status"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="Not set"
                        android:textColor="#94a3b8"
                        android:textSize="12sp"
                        android:background="@drawable/input_background_glass"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/perm_camera_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Allow"
                        android:textColor="#38bdf8"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_detect_glass"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- ── Location ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textColor="#e2e8f0"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Required for WiFi SSID detection"
                            android:textColor="#64748b"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/perm_location_status"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="Not set"
                        android:textColor="#94a3b8"
                        android:textSize="12sp"
                        android:background="@drawable/input_background_glass"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/perm_location_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Allow"
                        android:textColor="#38bdf8"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_detect_glass"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- ── Storage ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Storage"
                            android:textColor="#e2e8f0"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Required for file attachments and images"
                            android:textColor="#64748b"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/perm_storage_status"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:text="Not set"
                        android:textColor="#94a3b8"
                        android:textSize="12sp"
                        android:background="@drawable/input_background_glass"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/perm_storage_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Allow"
                        android:textColor="#38bdf8"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_detect_glass"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </FrameLayout>
</ScrollView>
